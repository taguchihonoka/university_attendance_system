<h1>ユーザー登録</h1>

<%= form_with(model: @user, local: true, html: { data: { turbo: false } }) do |form| %>
  <div>
  <%= form.label :role_id, 'ユーザー種別'%>
  <%= form.collection_select :role_id, Role.all, :id, :name, {} , { class: 'role-field' } %>
  </div>

  <div>
  <%= form.label :first_name, '姓'%>
  <%= form.text_field :first_name %>
  </div>

  <div>
  <%= form.label :last_name, '名'%>
  <%= form.text_field :last_name %>
  </div>

  <div>
  <%= form.label :first_name_kana, '姓(かな)'%>
  <%= form.text_field :first_name_kana %>
  </div>

  <div>
  <%= form.label :last_name_kana, '名(かな)'%>
  <%= form.text_field :last_name_kana %>
  </div>

  <div>
  <%= form.label :email, 'メールアドレス'%>
  <%= form.text_field :email %>
  </div>

  <div>
  <%= form.label :password, 'パスワード'%>
  <%= form.text_field :password %>
  </div>

  <div>
  <%= form.label :identifier, 'ログインID'%>
  <%= form.text_field :identifier %>
  </div>

  <div class='student-field' style='deisplay: none;'>
  <%= form.fields_for :student do |form| %>
    <div>
    <%= form.label :attendance_number, '出席番号'%>
    <%= form.text_field :attendance_number %>
    </div>

    <div>
    <%= form.label :faculty_id, '学部'%>
    <%= form.collection_select :faculty_id, Faculty.all, :id, :name %>
    </div>

    <div>
    <%= form.label :department_id, '学科'%>
    <%= form.collection_select :department_id, Department.all, :id, :name %>
    </div>

    <div>
    <%= form.label :grade, '学年'%>
    <%= form.select :grade, Student::GRADE_LABEL.map { |key, label|[label, key] } %>
    </div>

    <div>
    <%= form.label :enrolled_date, '入学日' %>
    <%= form.select :enrolled_year, options_for_select((Date.current.year - 10..Date.current.year).to_a.reverse) %>
    <%= form.select :enrolled_month, options_for_select((1..12).to_a) %>
    <%= form.select :enrolled_day, options_for_select((1..31).to_a) %>
    </div>

    <div>
    <%= form.label :graduated_date, '卒業日' %>
    <%= form.select :graduated_year, options_for_select([['未登録', '']] + (Date.current.year - 80..Date.current.year).to_a.reverse) %>
    <%= form.select :graduated_month, options_for_select([['未登録', '']] + ((1..12).to_a)) %>
    <%= form.select :graduated_day, options_for_select([['未登録', '']] + ((1..31).to_a)) %>
    </div>

    <div>
    <%= form.label :dropout_date, '中退日' %>
    <%= form.select :dropout_year, options_for_select([['未登録', '']] + ((Date.current.year - 80..Date.current.year).to_a.reverse)) %>
    <%= form.select :dropout_month, options_for_select([['未登録', '']] + ((1..12).to_a)) %>
    <%= form.select :dropout_day, options_for_select([['未登録', '']] + ((1..31).to_a)) %>
    </div>
  <% end %>
  </div>    


  <div class='teacher-field' style='deisplay: none;'>
  <%= form.fields_for :teacher do |form| %>
    <div>
    <%= form.label :instructor_number, '講師番号' %>
    <%= form.text_field :instructor_number %>
    </div>

    <div>
    <%= form.label :position, '職位' %>
    <%= form.collection_select :position_id, Position.all, :id, :name %>
    </div>

    <div >
    <%= form.label :faculty_id, '学部'%>
    <%= form.collection_select :faculty_id, Faculty.all, :id, :name %>
    </div>

    <div>
    <%= form.label :department_id, '学科'%>
    <%= form.collection_select :department_id, Department.all, :id, :name %>
    </div>

    <div>
    <%= form.label :assigned_date, '着任日' %>
    <%= form.select :assigned_year, options_for_select((Date.current.year - 50..Date.current.year).to_a.reverse) %>
    <%= form.select :assigned_month, options_for_select((1..12).to_a) %>
    <%= form.select :assigned_day, options_for_select((1..31).to_a) %>
    </div>

    <div>
    <%= form.label :retired_date, '離任日' %>
    <%= form.select :retired_year, options_for_select([['未登録', '']] + ((Date.current.year - 80..Date.current.year).to_a.reverse)) %>
    <%= form.select :retired_month, options_for_select([['未登録', '']] + ((1..12).to_a)) %>
    <%= form.select :retired_day, options_for_select([['未登録', '']] + ((1..31).to_a)) %>
    </div>
  <% end %>
  </div>

  <div class='admin-field' style='deisplay: none;'%>
  <%= form.fields_for :admin do |form| %>
    <div>
      <%= form.label :admin_number, '管理者番号' %>
      <%= form.text_field :admin_number %>
    </div>

    <div>
      <%= form.label :joined_date, '入社日' %>
      <%= form.select :joined_year, options_for_select((Date.current.year - 50..Date.current.year).to_a.reverse) %>
      <%= form.select :joined_month, options_for_select((1..12).to_a) %>
      <%= form.select :joined_day, options_for_select((1..31).to_a) %>
    </div>

    <div>
      <%= form.label :retired_date, '退職日' %>
      <%= form.select :retired_year, options_for_select([['未登録', '']] + ((Date.current.year - 80..Date.current.year).to_a.reverse)) %>
      <%= form.select :retired_month, options_for_select([['未登録', '']] + (1..12).to_a), {}, { id: 'admin_retired_month' } %>
      <%= form.select :retired_day, options_for_select([['未登録', '']] + (1..31).to_a) %>
    </div>
  <% end %>
  </div>

  <div>
    <%= form.submit '登録' %>
  </div>
<% end %>
